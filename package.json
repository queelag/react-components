    "@floating-ui/dom": "^1.7.6",
    "@lit-labs/react": "^2.1.3",
    "@microsoft/api-extractor": "^7.57.6",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dompurify": "^3.3.2",
    "esbuild": "^0.27.3",
