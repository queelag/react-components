{
  "author": "Dario Sechi",
  "devDependencies": {
    "@aracna/core": "workspace:*",
    "@aracna/react": "workspace:*",
    "@aracna/web": "workspace:*",
    "@aracna/web-components": "workspace:*",
    "@floating-ui/dom": "^1.7.4",
    "@lit-labs/react": "^2.1.3",
    "@microsoft/api-extractor": "^7.52.13",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dompurify": "^3.2.7",
    "esbuild": "^0.25.10",
    "esbuild-plugin-globals": "^0.2.0",
    "focus-trap": "^7.6.5",
    "glob": "^11.0.3",
    "jsdom": "^27.0.0",
    "lit": "^3.3.1",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tabbable": "^6.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./components/aria/*": {
      "types": "./components/aria/*.d.ts",
      "import": "./components/aria/*.js",
      "require": "./components/aria/*.cjs"
    },
    "./components/core/*": {
      "types": "./components/core/*.d.ts",
      "import": "./components/core/*.js",
      "require": "./components/core/*.cjs"
    },
    "./components/data/*": {
      "types": "./components/data/*.d.ts",
      "import": "./components/data/*.js",
      "require": "./components/data/*.cjs"
    },
    "./components/feedback/*": {
      "types": "./components/feedback/*.d.ts",
      "import": "./components/feedback/*.js",
      "require": "./components/feedback/*.cjs"
    },
    "./components/input/*": {
      "types": "./components/input/*.d.ts",
      "import": "./components/input/*.js",
      "require": "./components/input/*.cjs"
    },
    "./components/layout/*": {
      "types": "./components/layout/*.d.ts",
      "import": "./components/layout/*.js",
      "require": "./components/layout/*.cjs"
    },
    "./components/navigation/*": {
      "types": "./components/navigation/*.d.ts",
      "import": "./components/navigation/*.js",
      "require": "./components/navigation/*.cjs"
    },
    "./components/surface/*": {
      "types": "./components/surface/*.d.ts",
      "import": "./components/surface/*.js",
      "require": "./components/surface/*.cjs"
    },
    "./components/typography/*": {
      "types": "./components/typography/*.d.ts",
      "import": "./components/typography/*.js",
      "require": "./components/typography/*.cjs"
    }
  },
  "license": "MIT",
  "main": "index.cjs",
  "module": "index.js",
  "name": "@aracna/react-components",
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a",
  "peerDependencies": {
    "@aracna/core": ">= 1.3.0",
    "@aracna/react": ">= 1.0.0",
    "@aracna/web": ">= 1.0.0",
    "@aracna/web-components": ">= 1.1.0",
    "@floating-ui/dom": ">= 1.0.0",
    "@lit/react": ">= 1.0.0",
    "dompurify": ">= 3.0.0",
    "focus-trap": ">= 7.0.0",
    "lit": ">= 3.0.0",
    "qrcode": ">= 1.5.0",
    "react": ">= 19.0.0",
    "tabbable": ">= 6.0.0"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "repository": "https://github.com/queelag/react-components",
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublish": "vitest run && node scripts/build.mjs",
    "test": "vitest run"
  },
  "sideEffects": false,
  "type": "module",
  "types": "index.d.ts",
  "version": "1.0.57"
}
